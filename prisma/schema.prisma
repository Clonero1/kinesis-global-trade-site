generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  MANAGER
  ADMIN
}

enum ProductConditionCode {
  NEW
  USED
  REMANUFACTURED
  ON_ORDER
}

enum ProductIdentifierType {
  ARTICLE
  OEM
  CROSS
  SUPPLIER
  BARCODE
  OTHER
}

enum ProductPriceType {
  RETAIL
  WHOLESALE
  SPECIAL
}

enum SyncSource {
  ONE_C
  EXCEL
  CSV
  XML
  MANUAL
}

enum SyncBatchStatus {
  PENDING
  RUNNING
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
  CANCELLED
}

enum SyncEntityType {
  PRODUCT
  PRICE
  STOCK
  WAREHOUSE
  ORDER_STATUS
  DOCUMENT
}

enum SyncLogLevel {
  INFO
  WARNING
  ERROR
}

enum IntegrationSystem {
  ONE_C
  BITRIX24
  CDEK
  DELLIN
  AVITO
}

enum IntegrationTaskType {
  SEND_REQUEST_TO_ONE_C
  SYNC_PRODUCTS_FROM_ONE_C
  SYNC_PRICES_FROM_ONE_C
  SYNC_STOCKS_FROM_ONE_C
  SYNC_ORDER_STATUS_FROM_ONE_C
  SYNC_DOCUMENTS_FROM_ONE_C
  SEND_REQUEST_TO_BITRIX24
  GENERATE_AVITO_XML
}

enum IntegrationTaskStatus {
  PENDING
  SENDING
  SENT
  RETRY_WAIT
  FAILED
  CANCELLED
}

enum IntegrationDirection {
  INBOUND
  OUTBOUND
}

enum RequestStatus {
  DRAFT
  CREATED
  SENT_TO_ONE_C
  ACCEPTED_BY_ONE_C
  IN_WORK
  WAITING_PAYMENT
  PAID
  ASSEMBLING
  READY_TO_SHIP
  SHIPPED
  COMPLETED
  CANCELLED
  INTEGRATION_ERROR
}

enum OneCSendStatus {
  NOT_REQUIRED
  PENDING
  SENDING
  SENT
  RETRY_WAIT
  FAILED
  CANCELLED
}

enum DocumentType {
  INVOICE
  CONTRACT
  UNIVERSAL_TRANSFER_DOCUMENT
  WAYBILL
  ACT
  OTHER
}

enum DocumentStatus {
  DRAFT
  CREATED
  ACTIVE
  CANCELLED
  EXPIRED
}

enum SellerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  phone        String?
  role         UserRole @default(CUSTOMER)
  isActive     Boolean  @default(true)

  customers Customer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([isActive])
}

model Seller {
  id     String       @id @default(cuid())
  name   String
  status SellerStatus @default(ACTIVE)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model Brand {
  id     String  @id @default(cuid())
  onecId String? @unique
  name   String  @unique
  slug   String  @unique

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id       String  @id @default(cuid())
  onecId   String? @unique
  name     String
  slug     String  @unique
  parentId String?

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model ProductCondition {
  id          String               @id @default(cuid())
  code        ProductConditionCode @unique
  name        String
  description String?
  sortOrder   Int                  @default(0)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id            String   @id @default(cuid())
  onecId        String?  @unique
  name          String
  slug          String?  @unique
  description   String?
  applicability String?
  brandId       String?
  categoryId    String?
  conditionId   String?
  sellerId      String?
  weightKg      Decimal? @db.Decimal(12, 3)
  lengthMm      Decimal? @db.Decimal(12, 2)
  widthMm       Decimal? @db.Decimal(12, 2)
  heightMm      Decimal? @db.Decimal(12, 2)
  vatRate       Decimal? @db.Decimal(5, 2)
  isActive      Boolean  @default(true)
  source        SyncSource @default(ONE_C)
  syncedAt      DateTime?

  brand       Brand?            @relation(fields: [brandId], references: [id], onDelete: SetNull)
  category    Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  condition   ProductCondition? @relation(fields: [conditionId], references: [id], onDelete: SetNull)
  seller      Seller?           @relation(fields: [sellerId], references: [id], onDelete: SetNull)

  identifiers ProductIdentifier[]
  images      ProductImage[]
  attributes  ProductAttribute[]
  stocks      ProductStock[]
  prices      ProductPrice[]
  oneCMapping OneCProductMapping?
  requestItems RequestItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([onecId])
  @@index([brandId])
  @@index([categoryId])
  @@index([conditionId])
  @@index([sellerId])
  @@index([isActive])
  @@index([syncedAt])
}

model ProductIdentifier {
  id              String                @id @default(cuid())
  productId       String
  type            ProductIdentifierType @default(ARTICLE)
  originalValue   String
  normalizedValue String
  isPrimary       Boolean               @default(false)
  source          SyncSource            @default(ONE_C)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, type, normalizedValue])
  @@index([normalizedValue])
  @@index([type, normalizedValue])
  @@index([productId, isPrimary])
}

model ProductImage {
  id        String     @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int        @default(0)
  isPrimary Boolean    @default(false)
  source    SyncSource @default(ONE_C)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([productId, isPrimary])
}

model ProductAttribute {
  id        String     @id @default(cuid())
  productId String
  name      String
  value     String
  unit      String?
  sortOrder Int        @default(0)
  source    SyncSource @default(ONE_C)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([name])
}

model Warehouse {
  id       String  @id @default(cuid())
  onecId   String? @unique
  name     String
  code     String?
  address  String?
  city     String?
  isActive Boolean @default(true)
  syncedAt DateTime?

  stocks ProductStock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
}

model ProductStock {
  id                String   @id @default(cuid())
  productId         String
  warehouseId       String
  quantity          Decimal  @default(0) @db.Decimal(14, 3)
  reservedQuantity  Decimal  @default(0) @db.Decimal(14, 3)
  availableQuantity Decimal  @default(0) @db.Decimal(14, 3)
  syncBatchId       String?
  syncedAt          DateTime?

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  syncBatch SyncBatch? @relation(fields: [syncBatchId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, warehouseId])
  @@index([warehouseId])
  @@index([availableQuantity])
  @@index([syncedAt])
}

model ProductPrice {
  id          String           @id @default(cuid())
  productId   String
  priceType   ProductPriceType @default(RETAIL)
  amount      Decimal          @db.Decimal(14, 2)
  currency    String           @default("RUB")
  vatIncluded Boolean          @default(true)
  vatRate     Decimal?         @db.Decimal(5, 2)
  validFrom   DateTime?
  validTo     DateTime?
  syncBatchId String?
  syncedAt    DateTime?

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  syncBatch SyncBatch? @relation(fields: [syncBatchId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([productId, priceType])
  @@index([priceType])
  @@index([validFrom, validTo])
  @@index([syncedAt])
}

model OneCProductMapping {
  id        String   @id @default(cuid())
  productId String   @unique
  onecId    String   @unique
  onecCode  String?
  onecName  String?
  rawData   Json?
  syncedAt  DateTime?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([onecCode])
  @@index([syncedAt])
}

model SyncBatch {
  id          String          @id @default(cuid())
  source      SyncSource
  entity      SyncEntityType
  status      SyncBatchStatus @default(PENDING)
  startedAt   DateTime?
  finishedAt  DateTime?
  totalRows   Int             @default(0)
  successRows Int             @default(0)
  skippedRows Int             @default(0)
  errorRows   Int             @default(0)
  fileName    String?
  fileUrl     String?
  externalId  String?
  comment     String?

  logs   SyncLog[]
  stocks ProductStock[]
  prices ProductPrice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([source, entity])
  @@index([status])
  @@index([startedAt])
}

model SyncLog {
  id          String       @id @default(cuid())
  syncBatchId String
  level       SyncLogLevel @default(INFO)
  entity      String?
  entityId    String?
  rowNumber   Int?
  message     String
  details     Json?

  syncBatch SyncBatch @relation(fields: [syncBatchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([syncBatchId])
  @@index([level])
  @@index([entity, entityId])
}

model IntegrationTask {
  id             String                @id @default(cuid())
  system         IntegrationSystem
  type           IntegrationTaskType
  status         IntegrationTaskStatus @default(PENDING)
  entityType     String
  entityId       String
  requestId      String?
  idempotencyKey String?
  attemptCount   Int                   @default(0)
  maxAttempts    Int                   @default(10)
  nextAttemptAt  DateTime?
  lastAttemptAt  DateTime?
  lastError      String?
  payload        Json?
  response       Json?

  request Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  logs    IntegrationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([system, idempotencyKey])
  @@index([system, type])
  @@index([status])
  @@index([nextAttemptAt])
  @@index([entityType, entityId])
  @@index([requestId])
}

model IntegrationLog {
  id                String                @id @default(cuid())
  integrationTaskId String?
  system            IntegrationSystem
  direction         IntegrationDirection
  entityType        String?
  entityId          String?
  status            String
  attemptNumber     Int?
  operation         String?
  endpoint          String?
  durationMs        Int?
  externalId        String?
  errorCode         String?
  errorMessage      String?
  errorDetails      Json?
  payloadHash       String?
  safePayload       Json?
  safeResponse      Json?

  integrationTask IntegrationTask? @relation(fields: [integrationTaskId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([integrationTaskId])
  @@index([system, direction])
  @@index([entityType, entityId])
  @@index([status])
  @@index([createdAt])
}

model Customer {
  id     String  @id @default(cuid())
  userId String?
  name   String
  phone  String?
  email  String?

  user      User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  companies CustomerCompany[]
  requests  Request[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([phone])
  @@index([email])
}

model CustomerCompany {
  id          String  @id @default(cuid())
  customerId  String
  companyName String
  shortName   String?
  inn         String?
  kpp         String?
  ogrn        String?
  legalAddress String?
  actualAddress String?
  contactName String?
  phone       String?
  email       String?
  bankName    String?
  bik         String?
  correspondentAccount String?
  checkingAccount      String?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  requests Request[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([inn])
}

model Request {
  id                String        @id @default(cuid())
  requestNumber     String        @unique
  customerId        String?
  customerCompanyId String?
  status            RequestStatus @default(CREATED)
  onecSendStatus    OneCSendStatus @default(PENDING)
  onecOrderId       String?
  onecOrderNumber   String?
  onecSentAt        DateTime?
  onecUpdatedAt     DateTime?
  contactName       String?
  contactPhone      String?
  contactEmail      String?
  comment           String?
  managerComment    String?
  totalAmount       Decimal?      @db.Decimal(14, 2)
  currency          String?       @default("RUB")

  customer        Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerCompany CustomerCompany? @relation(fields: [customerCompanyId], references: [id], onDelete: SetNull)
  items           RequestItem[]
  deliveryInfo    DeliveryInfo?
  integrationTasks IntegrationTask[]
  documents       Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([customerCompanyId])
  @@index([status])
  @@index([onecSendStatus])
  @@index([onecOrderId])
  @@index([createdAt])
}

model RequestItem {
  id                       String   @id @default(cuid())
  requestId                String
  productId                String?
  lineNumber               Int
  requestedArticle         String
  matchedArticle           String?
  normalizedArticle        String?
  productNameSnapshot      String
  productConditionSnapshot String?
  warehouseIdSnapshot      String?
  warehouseNameSnapshot    String?
  stockAvailableSnapshot   Decimal? @db.Decimal(14, 3)
  priceSnapshot            Decimal? @db.Decimal(14, 2)
  currencySnapshot         String?  @default("RUB")
  quantity                 Decimal  @default(1) @db.Decimal(14, 3)
  onecProductIdSnapshot    String?

  request Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([requestId, lineNumber])
  @@index([requestId])
  @@index([productId])
  @@index([normalizedArticle])
}

model DeliveryInfo {
  id               String   @id @default(cuid())
  requestId        String   @unique
  method           String?
  carrier          String?
  city             String?
  address          String?
  pickupPointId    String?
  terminalId       String?
  recipientName    String?
  recipientPhone   String?
  cargoWeightKg    Decimal? @db.Decimal(12, 3)
  cargoLengthMm    Decimal? @db.Decimal(12, 2)
  cargoWidthMm     Decimal? @db.Decimal(12, 2)
  cargoHeightMm    Decimal? @db.Decimal(12, 2)
  calculatedPrice  Decimal? @db.Decimal(14, 2)
  currency         String?  @default("RUB")
  deliveryComment  String?

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carrier])
  @@index([city])
}

model Document {
  id           String         @id @default(cuid())
  requestId    String?
  type         DocumentType
  status       DocumentStatus @default(CREATED)
  onecId       String?        @unique
  onecNumber   String?
  title        String?
  documentDate DateTime?
  validUntil   DateTime?
  amount       Decimal? @db.Decimal(14, 2)
  currency     String?  @default("RUB")
  url          String?
  fileKey      String?
  mimeType     String?
  checksum     String?
  receivedAt   DateTime?

  request Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([onecId])
  @@index([requestId])
  @@index([type])
  @@index([status])
  @@index([documentDate])
}
